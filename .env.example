# Supabase — misma configuración en .env.local (PC) y en Vercel (producción)
# URL base del proyecto (NO incluir /rest/v1/)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Al hacer npm run dev, el proyecto sincroniza Supabase solo si cambió el catálogo.
# Forzar sync manual: npm run sync
# Desactivar auto-sync: GABI_SKIP_AUTO_SYNC=1

# URL pública del sitio (invitaciones admin coordinador)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Contraseña maestra operador/dueño (/operador, /admin/login). Opcional: si no se define, usa el valor por defecto del código.
GABI_MASTER_PASSWORD=

# Portal comercializadora (producción — obligatorio en Vercel)
# Desarrollo: si no se define, usa la contraseña de data.ts
PORTAL_BBR_PASSWORD=

# Simulador Investti — PIN compartido para gerentes/asesores (enlace /investti)
INVESTTI_SIMULADOR_PIN=

# Demo comercial — enlace de Cal.com o Calendly (muestra tu disponibilidad)
# Ejemplo Cal.com: https://cal.com/tu-usuario/demo-gabi
NEXT_PUBLIC_DEMO_BOOKING_URL=

# Email post-visita (Resend — https://resend.com)
RESEND_API_KEY=
# Remitente verificado en Resend, ej: gabi <hola@gabi.mx>
EMAIL_FROM=gabi <onboarding@resend.dev>

HUBSPOT_PRIVATE_APP_TOKEN=

# Webhook Parseur → leads en GABI (POST /api/webhooks/parseur?campanaId=...)
# En Parseur: Custom webhook + header Authorization: Bearer <secreto>
PARSEUR_WEBHOOK_SECRET=

# Webhook ADRYO → encuestas QA / satisfacción (POST /api/webhooks/qa)
QA_WEBHOOK_SECRET=

# Google Drive — expedientes (Pasaje Álamos)
GOOGLE_SERVICE_ACCOUNT_CLIENT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
GOOGLE_DRIVE_PASAJE_ALAMOS_FOLDER_ID=

# Google Maps — mapa interactivo corredor sur (/corredor)
# Crear key en Google Cloud → Maps JavaScript API
# Referrers permitidos: localhost:3000, www.gabi.mx, gabi.mx, *.vercel.app
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
