# Supabase — misma configuración en .env.local (PC) y en Vercel (producción)
# URL base del proyecto (NO incluir /rest/v1/)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Al hacer npm run dev, el proyecto sincroniza Supabase solo si cambió el catálogo.
# Forzar sync manual: npm run sync
# Desactivar auto-sync: GABI_SKIP_AUTO_SYNC=1

# URL pública del sitio (invitaciones admin coordinador)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Marca DMB — mismo deploy Vercel/Supabase que gabi (dominio adicional dmb.mx)
NEXT_PUBLIC_DMB_SITE_URL=http://localhost:3000/dmb

# Contraseña maestra operador/dueño (/operador, /admin/login).
# En Vercel usa GABI_MASTER_PASSWORD (preferido) o GABI_OPERATOR_ACCESS_CODE (legacy).
GABI_MASTER_PASSWORD=
# GABI_OPERATOR_ACCESS_CODE=

# Portal comercializadora (producción — obligatorio en Vercel)
# Desarrollo: si no se define, usa la contraseña de data.ts
PORTAL_BBR_PASSWORD=

# Simulador Investti — PIN compartido para gerentes/asesores (enlace /investti)
INVESTTI_SIMULADOR_PIN=

# Demo comercial — enlace de Cal.com o Calendly (muestra tu disponibilidad)
# Ejemplo Cal.com: https://cal.com/tu-usuario/demo-gabi
NEXT_PUBLIC_DEMO_BOOKING_URL=

# Email transaccional GABI (Resend — https://resend.com)
# Obligatorio para: solicitudes de apartado a gerencia, acceso admin gerente, digest CRM.
RESEND_API_KEY=
# Remitente verificado en Resend (dominio gabi.mx), ej: gabi <hola@gabi.mx>
EMAIL_FROM=gabi <onboarding@resend.dev>

# Cron Vercel — digest diario de cumplimiento CRM (lun-sáb 8:00 UTC)
CRON_SECRET=

# Web Push (PWA) — recordatorios de pendientes CRM en el celular
# Generar: npm run vapid:generate
# Público también en el cliente (NEXT_PUBLIC_*)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# mailto: o URL del contacto del sitio
VAPID_SUBJECT=mailto:hola@gabi.mx

# Cumplimiento CRM — asesores por comisión (equilibrio motivación / accountability)
# nudge: desde N vencidos (recordatorio). coach: umbral medio. pause: frena recorrido/cotizador.
COMPLIANCE_NUDGE_OVERDUE=1
COMPLIANCE_RECORRIDO_BLOCK_OVERDUE=3
COMPLIANCE_PAUSE_OVERDUE=6
# Solo aplica en nivel pause si true (mis-leads siempre libre)
COMPLIANCE_SERVER_ENFORCE=false

HUBSPOT_PRIVATE_APP_TOKEN=

# Webhook Parseur → leads en GABI (POST /api/webhooks/parseur?campanaId=...)
# En Parseur: Custom webhook + header Authorization: Bearer <secreto>
PARSEUR_WEBHOOK_SECRET=

# Webhook ADRYO → encuestas QA / satisfacción (POST /api/webhooks/qa)
QA_WEBHOOK_SECRET=

# Opcional — aplicar migraciones desde terminal (npm run db:apply:037-038)
# o botón en admin → Salud de plataforma (Vercel)
# URI completa O solo contraseña (se infiere el host desde NEXT_PUBLIC_SUPABASE_URL)
SUPABASE_DB_URL=
SUPABASE_DB_PASSWORD=

# Sesión asesor (cookie firmada tras PIN).
# OBLIGATORIO en producción (Vercel). En local usa SERVICE_ROLE o fallback de desarrollo.
ASESOR_SESSION_SECRET=

# Observabilidad — Sentry (opcional; sin DSN la app funciona igual)
# Crea proyecto en sentry.io → Settings → Client Keys (DSN)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Google Drive — expedientes (Pasaje Álamos, Misión La Gavia)
GOOGLE_SERVICE_ACCOUNT_CLIENT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
GOOGLE_DRIVE_PASAJE_ALAMOS_FOLDER_ID=
GOOGLE_DRIVE_MISION_LA_GAVIA_FOLDER_ID=

# Google Maps — mapa interactivo corredor sur (/corredor)
# Crear key en Google Cloud → Maps JavaScript API
# Referrers permitidos: localhost:3000, www.gabi.mx, gabi.mx, *.vercel.app
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
