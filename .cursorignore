# GABI — excluir del índice de Cursor (menos ruido, respuestas más rápidas)
# El código sigue compilando; solo deja de indexarse para búsqueda del agente.

# --- Dependencias y artefactos de build (~60k archivos) ---
node_modules/
.next/
out/
build/
coverage/
dist/

# --- Control de versiones y caché local ---
.git/
.vercel/
.gabi/
supabase/.temp/

# --- Scratch / extracciones Office (gavia, brochures) ---
.tmp/

# --- Secretos (nunca indexar) ---
.env
.env.*
!.env.example

# --- PWA generado por next-pwa ---
public/sw.js
public/workbox-*.js
public/fallback-*.js

# --- Catálogos generados por npm run sync (fuente: scripts/*.json + build-*.cjs) ---
**/*.generated.ts

# --- Bundles SQL duplicados (usar migraciones 0XX_*.sql numeradas) ---
supabase/migrations/_bundle_*.sql
supabase/migrations/*.deprecated

# --- Binarios: el agente usa rutas, no necesita leer bytes ---
public/**/*.pdf
public/**/*.jpg
public/**/*.jpeg
public/**/*.png
public/**/*.gif
public/**/*.webp
public/**/*.ico
public/**/*.mp4
public/**/*.woff
public/**/*.woff2
public/**/*.ttf
public/**/*.eot

# --- Docs pesados (mantener .md indexables) ---
docs/**/*.pdf

# --- Lockfile enorme; dependencias en package.json ---
package-lock.json

# --- Logs y basura de tooling ---
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.tsbuildinfo
next-env.d.ts
.DS_Store
Thumbs.db
scripts/extract-output.txt
